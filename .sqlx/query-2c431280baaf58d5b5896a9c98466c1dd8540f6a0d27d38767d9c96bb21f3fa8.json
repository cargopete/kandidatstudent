{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, scrape_job_id, status AS \"status: _\",\n                   started_at, finished_at, rows_found, rows_upserted, rows_deleted,\n                   error_message, log_s3_key, snapshot_id\n            FROM scrape_run\n            WHERE ($1::text IS NULL OR status::text = $1)\n            ORDER BY started_at DESC\n            LIMIT $2\n            ",
