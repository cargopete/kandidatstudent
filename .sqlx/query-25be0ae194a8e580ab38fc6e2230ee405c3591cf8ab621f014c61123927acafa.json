  "query": "\n            SELECT id, slug, canonical_name_bg, canonical_name_en,\n                   professional_field_id, description_bg, created_at, updated_at\n            FROM specialty\n            WHERE ($1::bigint IS NULL OR professional_field_id = $1)\n            ORDER BY canonical_name_bg ASC\n            LIMIT $2 OFFSET $3\n            ",
