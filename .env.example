# Postgres
POSTGRES_PASSWORD=change-me-strong-password

# Meilisearch
MEILI_MASTER_KEY=change-me-strong-key

# Admin API
ADMIN_BEARER_TOKEN=change-me-bearer-token

# Vercel ISR revalidation
VERCEL_REVALIDATE_URL=https://kandidatstudent.bg/api/revalidate
VERCEL_REVALIDATE_SECRET=change-me-revalidate-secret

# Cloudflare (for Caddy DNS-01 + CF API token)
CF_API_TOKEN=your-cloudflare-api-token-with-dns-edit

# Hetzner Object Storage (S3-compatible)
S3_BUCKET=kandidatstudent-raw
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
AWS_ACCESS_KEY_ID=your-hetzner-access-key
AWS_SECRET_ACCESS_KEY=your-hetzner-secret-key
